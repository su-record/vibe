{
  "name": "@su-record/core",
  "version": "0.1.17",
  "description": "Su core - Claude Code exclusive SPEC-driven AI coding framework with 35+ integrated tools",
  "type": "module",
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./tools": "./dist/tools/index.js",
    "./tools/memory": "./dist/tools/memory/index.js",
    "./tools/convention": "./dist/tools/convention/index.js",
    "./tools/semantic": "./dist/tools/semantic/index.js",
    "./tools/ui": "./dist/tools/ui/index.js",
    "./tools/time": "./dist/tools/time/index.js",
    "./tools/interaction": "./dist/tools/interaction/index.js",
    "./orchestrator": "./dist/orchestrator/index.js",
    "./lib/gpt": "./dist/lib/gpt-api.js",
    "./lib/gemini": "./dist/lib/gemini-api.js",
    "./lib/kimi": "./dist/lib/kimi-api.js"
  },
  "bin": {
    "vibe": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/cli/postinstall.js || true",
    "deploy": "npm version patch --no-git-tag-version && npm run build && npm publish"
  },
  "keywords": [
    "ai",
    "core",
    "coding",
    "spec-driven",
    "claude",
    "framework",
    "requirements",
    "user-story",
    "ultrawork",
    "parallel-agents",
    "memory-management",
    "knowledge-graph",
    "code-analysis",
    "code-quality"
  ],
  "author": "Su",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/su-record/core.git"
  },
  "homepage": "https://github.com/su-record/core#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.6",
    "better-sqlite3": "^12.4.1",
    "chalk": "^5.3.0",
    "glob": "^13.0.1",
    "node-cron": "^3.0.3",
    "ts-morph": "^26.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.5.4",
    "vitest": "^4.0.9"
  },
  "files": [
    "dist/",
    "vibe/",
    "languages/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ]
}
