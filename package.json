{
  "name": "@su-record/core",
  "version": "0.1.36",
  "description": "Personalized AI agent for Claude Code — 46 agents, 41+ tools, multi-LLM orchestration",
  "type": "module",
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "default": "./dist/agent/index.js"
    },
    "./tools": "./dist/tools/index.js",
    "./tools/memory": "./dist/tools/memory/index.js",
    "./tools/convention": "./dist/tools/convention/index.js",
    "./tools/semantic": "./dist/tools/semantic/index.js",
    "./tools/ui": "./dist/tools/ui/index.js",
    "./tools/time": "./dist/tools/time/index.js",
    "./tools/interaction": "./dist/tools/interaction/index.js",
    "./orchestrator": "./dist/orchestrator/index.js",
    "./interface": {
      "types": "./dist/interface/index.d.ts",
      "default": "./dist/interface/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./memory": {
      "types": "./dist/lib/memory/index.d.ts",
      "default": "./dist/lib/memory/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "default": "./dist/policy/index.js"
    },
    "./lib/gpt": "./dist/lib/gpt-api.js",
    "./lib/gemini": "./dist/lib/gemini-api.js",
    "./lib/kimi": "./dist/lib/az-api.js",
    "./lib/az": "./dist/lib/az-api.js"
  },
  "bin": {
    "vibe": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "postinstall": "node -e \"import('./dist/cli/postinstall/main.js').then(m=>m.main()).catch(()=>{})\"",
    "deploy": "pnpm version patch --no-git-tag-version && pnpm build && pnpm publish --no-git-checks"
  },
  "keywords": [
    "ai",
    "core",
    "coding",
    "spec-driven",
    "claude",
    "agent",
    "requirements",
    "user-story",
    "ultrawork",
    "parallel-agents",
    "memory-management",
    "knowledge-graph",
    "code-analysis",
    "code-quality"
  ],
  "author": "Su",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/su-record/core.git"
  },
  "homepage": "https://github.com/su-record/core#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.6",
    "@clack/prompts": "^1.0.0",
    "@clack/prompts": "^1.0.0",
    "better-sqlite3": "^12.4.1",
    "chalk": "^5.3.0",
    "glob": "^13.0.1",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "playwright": "^1.58.2",
    "ts-morph": "^26.0.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "ajv": "^8.17.1",
    "typescript": "^5.5.4",
    "vitest": "^4.0.9"
  },
  "files": [
    "dist/",
    "vibe/",
    "languages/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ]
}
