{
  "name": "resource-limit",
  "version": "1.0.0",
  "type": "configuration",
  "enabled": true,
  "rules": [
    {
      "id": "rl-001",
      "description": "Warn on large number of file modifications",
      "condition": { "estimatedFiles": { "gt": 10 } },
      "effect": "warn",
      "message": "Modifying more than 10 files at once",
      "severity": "medium"
    },
    {
      "id": "rl-002",
      "description": "Warn on deploy action",
      "condition": { "action.type": { "equals": "deploy" } },
      "effect": "warn",
      "message": "Deployment action detected",
      "severity": "medium"
    }
  ]
}
