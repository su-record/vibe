{
  "_comment": "Hook ordering rationale — SessionStart: init state. PreToolUse: sentinel-guard (catastrophic command blocker) BEFORE pre-tool-guard (project-specific). PostToolUse: format → lint → test (normalize style, then catch issues, then verify behavior). UserPromptSubmit: interrupt echo FIRST to inject cancellation signal BEFORE dispatcher processes new prompt. Notification: 80/90/95% thresholds trigger progressively urgent context saves.",
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/sentinel-guard.js Bash"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-guard.js Bash"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/command-log.js"
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pr-test-gate.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/sentinel-guard.js Edit"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-guard.js Edit"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/sentinel-guard.js Write"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-guard.js Write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/auto-format.js"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/code-check.js"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/auto-test.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/post-edit.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[INTERRUPT RULE] If this message follows a user interrupt (Ctrl+C/Escape), the previous task is CANCELLED. Do NOT resume interrupted work. Respond ONLY to this new message.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/prompt-dispatcher.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "context_window_80",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js medium"
          }
        ]
      },
      {
        "matcher": "context_window_90",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js high"
          }
        ]
      },
      {
        "matcher": "context_window_95",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js critical"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/codex-review-gate.js"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/stop-notify.js"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/auto-commit.js"
          },
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/devlog-gen.js"
          }
        ]
      }
    ]
  }
}
