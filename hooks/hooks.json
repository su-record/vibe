{
  "_comment": "Dispatcher pattern — PreToolUse/PostToolUse/Stop는 단일 디스패처가 stdin을 한 번 읽어 순차 실행 (병렬 spawn 폭주 제거, cascade 격리, config.hooks.{name}.enabled 토글 지원). UserPromptSubmit은 VIBE_HOOK_DEPTH 재귀 가드 탑재된 prompt-dispatcher 사용.",
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-dispatcher.js Bash"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-dispatcher.js Edit"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pre-tool-dispatcher.js Write"
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/pr-test-gate.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/post-edit-dispatcher.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/post-tool-failure.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/step-counter.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[INTERRUPT RULE] If this message follows a user interrupt (Ctrl+C/Escape), the previous task is CANCELLED. Do NOT resume interrupted work. Respond ONLY to this new message.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/prompt-dispatcher.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "context_window_80",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js medium"
          }
        ]
      },
      {
        "matcher": "context_window_90",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js high"
          }
        ]
      },
      {
        "matcher": "context_window_95",
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/context-save.js critical"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{VIBE_PATH}}/hooks/scripts/stop-dispatcher.js"
          }
        ]
      }
    ]
  }
}
